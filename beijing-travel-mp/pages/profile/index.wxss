.profile-head { display:flex; min-width:0; align-items:center; margin:20rpx 0 34rpx; }.profile-head > view:last-child { min-width:0; }.avatar { width:92rpx; height:92rpx; flex:none; border-radius:50%; background:var(--ink-green); color:#FFF; display:flex; align-items:center; justify-content:center; font-size:40rpx; margin-right:22rpx; }.hello { font-size:40rpx; font-weight:700; }.section { margin-bottom:34rpx; }.section-title { display:flex; min-width:0; justify-content:space-between; font-size:34rpx; font-weight:700; margin-bottom:18rpx; }.clear { flex:none; color:var(--vermilion); font-size:23rpx; font-weight:400; }.section place-card { display:block; width:100%; margin-bottom:18rpx; }
.food-saved { display:flex; align-items:center; gap:16rpx; width:100%; box-sizing:border-box; padding:14rpx; margin-bottom:18rpx; background:var(--surface); border:1rpx solid rgba(38,50,56,.07); border-radius:16rpx; color:var(--vermilion); font-size:36rpx; }.food-saved-cover { width:112rpx; height:112rpx; flex:none; border-radius:10rpx; background:var(--soft-green); }.food-saved-copy { flex:1; min-width:0; color:var(--ink); font-size:28rpx; font-weight:700; }.food-saved-meta { overflow:hidden; margin-top:8rpx; color:var(--muted); font-size:22rpx; font-weight:400; text-overflow:ellipsis; white-space:nowrap; }
