<view class="page safe-bottom"><view class="profile-head"><view class="avatar">京</view><view><view class="hello">我的北京</view><view class="muted">把喜欢的地方留在这里</view></view></view><view class="section"><view class="section-title"><text>我的收藏</text><text wx:if="{{favorites.length}}" class="clear" bindtap="clearFavorites">清空</text></view><block wx:for="{{favorites}}" wx:key="id"><place-card wx:if="{{item.contentType === 'place'}}" place="{{item}}" bind:tap="onPlace"></place-card><view wx:else class="food-saved" data-id="{{item.id}}" bindtap="onFood"><image class="food-saved-cover" src="{{item.cover}}" mode="aspectFill"></image><view class="food-saved-copy"><view>{{item.name}}</view><view class="food-saved-meta">美食收藏 · {{item.rating}} 星推荐</view></view><text>›</text></view></block><empty-state wx:if="{{!favorites.length}}" title="还没有收藏" description="在景点或美食详情页点亮收藏，方便下次再看"></empty-state></view><view class="section"><view class="section-title"><text>阅读历史</text><text wx:if="{{history.length}}" class="clear" bindtap="clearHistory">清空</text></view><block wx:for="{{history}}" wx:key="id"><place-card wx:if="{{item.contentType === 'place'}}" place="{{item}}" bind:tap="onPlace"></place-card><view wx:else class="food-saved" data-id="{{item.id}}" bindtap="onFood"><image class="food-saved-cover" src="{{item.cover}}" mode="aspectFill"></image><view class="food-saved-copy"><view>{{item.name}}</view><view class="food-saved-meta">美食浏览记录 · {{item.rating}} 星推荐</view></view><text>›</text></view></block><empty-state wx:if="{{!history.length}}" title="还没有阅读记录" description="探索一些景点或美食，最近看过的内容会出现在这里"></empty-state></view></view>
