<scroll-view scroll-y class="page safe-bottom"><view class="page-heading">探索北京<text>从熟悉的地标，到胡同深处的惊喜</text></view><view class="search-box">⌕ <input value="{{keyword}}" placeholder="搜索景点、标签或关键词" bindinput="onInput" /></view><scroll-view scroll-x class="filters"><text class="filter {{active === '' ? 'selected' : ''}}" data-id="" bindtap="onCategory">全部</text><text wx:for="{{categories}}" wx:key="id" class="filter {{active === item.id ? 'selected' : ''}}" data-id="{{item.id}}" bindtap="onCategory">{{item.name}}</text></scroll-view><view class="list"><place-card wx:for="{{places}}" wx:key="id" place="{{item}}" bind:tap="onPlace"></place-card><empty-state wx:if="{{!places.length}}" title="还没有找到" description="换个关键词，或看看全部分类" button-text="清除筛选" bind:actiontap="clear"></empty-state></view></scroll-view>
