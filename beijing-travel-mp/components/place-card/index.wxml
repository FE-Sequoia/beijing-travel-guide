<view class="card {{variant}}" bindtap="onTap"><image class="cover" src="{{place.cover}}" mode="aspectFill"></image><view class="body"><view class="category">{{place.categoryName}}</view><view class="name">{{place.name}}</view><view class="summary">{{place.summary}}</view><view class="tags"><text wx:for="{{place.tags}}" wx:key="*this" class="tag">{{item}}</text></view></view></view>
