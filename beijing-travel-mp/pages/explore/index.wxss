.page-heading { font-size:44rpx; font-weight:700; margin:20rpx 0 26rpx; }.page-heading text { display:block; color:#718096; font-size:23rpx; font-weight:400; line-height:1.65; margin-top:10rpx; }.search-box { display:flex; align-items:center; min-width:0; background:rgba(255,252,247,.78); border:1rpx solid rgba(38,50,56,.05); border-radius:16rpx; padding:4rpx 20rpx; color:#2E7D6B; }.search-box input { flex:1; min-width:0; padding:18rpx 10rpx; font-size:25rpx; }.filters { width:100%; white-space:nowrap; margin:26rpx 0 18rpx; }.filter { display:inline-block; padding:13rpx 22rpx; background:rgba(228,239,233,.72); color:#718096; border-radius:30rpx; margin-right:12rpx; font-size:23rpx; }.filter.selected { color:#FFF; background:#2E7D6B; }.result-bar { display:flex; min-width:0; justify-content:space-between; align-items:center; color:#718096; font-size:22rpx; margin-bottom:18rpx; }.sort { color:#2E7D6B; background:rgba(228,239,233,.72); border-radius:20rpx; padding:9rpx 16rpx; }.list place-card { display:block; width:100%; margin-bottom:18rpx; }
