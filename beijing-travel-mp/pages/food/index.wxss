.page-heading { font-size:44rpx; font-weight:700; margin:20rpx 0 24rpx; }
.page-heading text { display:block; color:var(--muted); font-size:23rpx; font-weight:400; line-height:1.65; margin-top:10rpx; }
.intro-card { margin-bottom:28rpx; padding:20rpx 22rpx; color:#FFF; background:linear-gradient(135deg,#1F5B4F,#477D6D); border-radius:18rpx; box-shadow:0 10rpx 24rpx rgba(31,91,79,.13); }
.intro-kicker { opacity:.72; font-size:18rpx; letter-spacing:2rpx; }
.intro-copy { margin-top:8rpx; font-size:28rpx; font-weight:700; }
.food-grid { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:20rpx; width:100%; }
.food-card { overflow:hidden; min-width:0; background:var(--surface); border:1rpx solid rgba(38,50,56,.07); border-radius:18rpx; box-shadow:0 8rpx 22rpx rgba(38,50,56,.06); }
.cover { display:block; width:100%; height:210rpx; background:var(--soft-green); }
.fallback { display:flex; align-items:flex-end; box-sizing:border-box; padding:16rpx; color:#FFF; background:linear-gradient(135deg,#B9513A,#D58467); font-size:23rpx; font-weight:700; line-height:1.4; }
.card-body { min-width:0; padding:17rpx 16rpx 18rpx; }
.food-name { overflow:hidden; color:var(--ink); font-size:26rpx; font-weight:700; line-height:1.45; text-overflow:ellipsis; white-space:nowrap; }
.rating { margin-top:9rpx; font-size:21rpx; letter-spacing:1rpx; }
.star { color:#D8D5CE; }
.star.active { color:var(--vermilion); }
