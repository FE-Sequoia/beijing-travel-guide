<view class="page safe-bottom">
  <view class="page-heading">吃在北京<text>从一口京味，读懂一座城的日常</text></view>
  <view class="intro-card">
    <view class="intro-kicker">LOCAL EDITS</view>
    <view class="intro-copy">十二家值得绕路的馆子</view>
  </view>
  <view class="food-grid">
    <view wx:for="{{foods}}" wx:key="id" class="food-card" data-id="{{item.id}}" bindtap="onFood">
      <image wx:if="{{!item.coverFailed}}" class="cover" src="{{item.cover}}" mode="aspectFill" data-index="{{index}}" binderror="onCoverError"></image>
      <view wx:else class="cover fallback">{{item.name}}</view>
      <view class="card-body">
        <view class="food-name">{{item.name}}</view>
        <view class="rating" aria-label="推荐指数 {{item.rating}} 星">
          <text wx:for="{{stars}}" wx:key="*this" class="star {{item <= food.rating ? 'active' : ''}}">★</text>
        </view>
      </view>
    </view>
  </view>
</view>
