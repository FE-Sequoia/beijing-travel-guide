.page-heading { font-size:44rpx; font-weight:700; margin:20rpx 0 26rpx; }.page-heading text { display:block; color:#718096; font-size:23rpx; font-weight:400; margin-top:9rpx; }.search-box { display:flex; align-items:center; background:#FFFDF9; border-radius:16rpx; padding:4rpx 20rpx; color:#2E7D6B; }.search-box input { flex:1; padding:18rpx 10rpx; font-size:25rpx; }.filters { white-space:nowrap; margin:26rpx -24rpx 18rpx; padding-left:24rpx; }.filter { display:inline-block; padding:13rpx 22rpx; background:#EEF2EE; color:#718096; border-radius:30rpx; margin-right:12rpx; font-size:23rpx; }.filter.selected { color:#FFF; background:#2E7D6B; }.result-bar { display:flex; justify-content:space-between; align-items:center; color:#718096; font-size:22rpx; margin-bottom:18rpx; }.sort { color:#2E7D6B; background:#E8F2EC; border-radius:20rpx; padding:9rpx 16rpx; }.list place-card { display:block; margin-bottom:18rpx; }
