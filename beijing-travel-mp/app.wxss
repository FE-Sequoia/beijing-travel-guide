page { --paper:#F7F3EC; --surface:#FFFCF7; --ink:#263238; --muted:#6E746F; --ink-green:#1F5B4F; --soft-green:#E4EFE9; --vermilion:#B9513A; background:var(--paper); color:var(--ink); overflow-x:hidden; font-family:-apple-system-font,BlinkMacSystemFont,"Helvetica Neue",sans-serif; }
page, view, scroll-view, image, text, input, button { box-sizing:border-box; }
.page { width:100%; min-width:0; padding:32rpx 32rpx 0; }
.card, .surface { width:100%; min-width:0; background:var(--surface); border:1rpx solid rgba(38,50,56,.06); border-radius:24rpx; box-shadow:0 10rpx 28rpx rgba(53,72,65,.045); }
.muted { color:var(--muted); }
.green { color:var(--ink-green); }
.red { color:var(--vermilion); }
.section-gap { margin-top:48rpx; }
.safe-bottom { padding-bottom:calc(32rpx + env(safe-area-inset-bottom)); }

.eyebrow { color:var(--ink-green); font-size:20rpx; font-weight:600; letter-spacing:3rpx; }
.page-heading { color:var(--ink); font-size:44rpx; font-weight:700; line-height:1.3; }
.page-lede { color:var(--muted); font-size:24rpx; line-height:1.65; margin-top:10rpx; }
.body-copy { color:#48524E; font-size:27rpx; line-height:1.9; white-space:pre-line; }
.meta-row { display:flex; align-items:center; color:var(--muted); font-size:22rpx; line-height:1.5; }
.pill { display:inline-flex; align-items:center; padding:8rpx 16rpx; background:var(--soft-green); border-radius:999rpx; color:var(--ink-green); font-size:21rpx; line-height:1.4; }
.hairline-list { border-top:1rpx solid rgba(38,50,56,.1); }
.hairline-list > view { border-bottom:1rpx solid rgba(38,50,56,.1); }
