.detail { min-height:100vh; }.hero { width:100%; height:430rpx; background:#E8F2EC; }.body { padding:28rpx 30rpx 60rpx; }.category { color:#2E7D6B; font-size:23rpx; }.title-row { display:flex; align-items:center; justify-content:space-between; margin-top:10rpx; }.title { font-size:48rpx; font-weight:700; }.favorite { width:68rpx; height:68rpx; border-radius:50%; background:#F3EFE8; display:flex; align-items:center; justify-content:center; color:#B9513A; font-size:38rpx; }.favorite.active { background:#F9E8E2; }.summary { color:#718096; font-size:27rpx; line-height:1.7; margin-top:16rpx; }.tags { margin-top:18rpx; }.tag { display:inline-block; color:#2E7D6B; background:#E8F2EC; border-radius:8rpx; padding:7rpx 12rpx; font-size:21rpx; margin-right:10rpx; }.info { display:flex; margin-top:28rpx; padding:22rpx; }.info-item { flex:1; color:#263238; font-size:23rpx; }.info-label { color:#718096; font-size:20rpx; margin-bottom:8rpx; }.section { margin-top:36rpx; }.section-title { font-size:32rpx; font-weight:700; margin-bottom:12rpx; }.copy { color:#4A5568; font-size:27rpx; line-height:1.85; }
