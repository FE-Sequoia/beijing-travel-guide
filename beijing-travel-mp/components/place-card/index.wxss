.card { width:100%; min-width:0; box-sizing:border-box; overflow:hidden; background:var(--surface); border:1rpx solid rgba(38,50,56,.06); border-radius:24rpx; box-shadow:0 10rpx 28rpx rgba(53,72,65,.045); }
.cover { width:100%; aspect-ratio:16 / 9; background:var(--soft-green); }
.fallback { display:flex; align-items:flex-end; padding:20rpx; color:var(--surface); font-size:24rpx; font-weight:700; background:linear-gradient(135deg,var(--ink-green),var(--soft-green)); }
.body { min-width:0; padding:20rpx; }
.category { color:var(--ink-green); font-size:21rpx; }
.name { font-size:31rpx; font-weight:700; margin-top:7rpx; }
.summary { display:-webkit-box; overflow:hidden; -webkit-box-orient:vertical; -webkit-line-clamp:2; color:var(--muted); font-size:23rpx; line-height:1.65; margin-top:9rpx; }
.tags { margin-top:12rpx; }
.tag { color:var(--muted); background:var(--soft-green); border-radius:999rpx; padding:5rpx 10rpx; font-size:20rpx; margin-right:8rpx; }
.compact { display:block; width:100%; min-width:0; }
.compact .cover { width:100%; height:auto; aspect-ratio:1 / 1; }
.compact .body { padding:18rpx; }
.compact .name { font-size:27rpx; line-height:1.4; }
.compact .summary, .compact .tags { display:none; }
