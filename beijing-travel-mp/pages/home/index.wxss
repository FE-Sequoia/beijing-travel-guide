.greeting { color:#718096; font-size:24rpx; letter-spacing:2rpx; margin-bottom:20rpx; }.hero { background:linear-gradient(135deg,#2E7D6B,#5E9A83); color:#FFF; border-radius:28rpx; padding:38rpx 32rpx 28rpx; }.eyebrow { opacity:.75; font-size:20rpx; letter-spacing:3rpx; }.hero-title { font-size:46rpx; line-height:1.35; font-weight:700; margin:24rpx 0 34rpx; }.search { background:rgba(255,255,255,.94); color:#718096; border-radius:14rpx; padding:20rpx 22rpx; font-size:27rpx; }.search text { margin-left:12rpx; font-size:24rpx; }.categories,.places { white-space:nowrap; }.category { display:inline-flex; vertical-align:top; flex-direction:column; align-items:center; justify-content:center; width:150rpx; height:130rpx; border-radius:18rpx; margin-right:16rpx; font-size:23rpx; }.emoji { font-size:42rpx; margin-bottom:10rpx; }.places place-card { display:inline-block; vertical-align:top; margin-right:18rpx; }.places { margin-right:-24rpx; }.section-gap place-card { display:block; margin-bottom:18rpx; }
