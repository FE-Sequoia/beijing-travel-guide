.page-heading { font-size:44rpx; font-weight:700; margin:20rpx 0 26rpx; }.page-heading text { display:block; color:#718096; font-size:23rpx; font-weight:400; line-height:1.65; margin-top:10rpx; }.notice { padding:18rpx 20rpx; border-radius:14rpx; background:rgba(228,239,233,.72); color:#2E7D6B; font-size:22rpx; }.itinerary-list { margin-top:24rpx; }.itinerary { display:flex; align-items:center; width:100%; padding:24rpx; margin-bottom:18rpx; }.days { width:82rpx; height:82rpx; flex:none; display:flex; align-items:center; justify-content:center; border-radius:18rpx; background:#F9E8E2; color:#B9513A; font-size:24rpx; font-weight:700; }.content { flex:1; min-width:0; margin-left:20rpx; }.title { font-size:30rpx; font-weight:700; }.summary { color:#718096; font-size:23rpx; line-height:1.55; margin-top:8rpx; }.theme { color:#2E7D6B; font-size:20rpx; margin-top:10rpx; }.arrow { flex:none; color:#B9513A; font-size:42rpx; }
