.card { width:100%; min-width:0; overflow:hidden; background:#FFFDF9; border-radius:20rpx; box-shadow:0 8rpx 28rpx rgba(53,72,65,.07); }
.cover { width:100%; aspect-ratio:16 / 9; background:#E8F2EC; }
.fallback { display:flex; align-items:flex-end; padding:20rpx; color:#FFF; font-size:24rpx; font-weight:700; background:linear-gradient(135deg,#2E7D6B,#8BB59D); }
.body { min-width:0; padding:20rpx; }
.category { color:#2E7D6B; font-size:21rpx; }
.name { font-size:31rpx; font-weight:700; margin-top:7rpx; }
.summary { display:-webkit-box; overflow:hidden; -webkit-box-orient:vertical; -webkit-line-clamp:2; color:var(--muted); font-size:23rpx; line-height:1.65; margin-top:9rpx; }
.tags { margin-top:12rpx; }
.tag { color:var(--muted); background:rgba(31,91,79,.08); border-radius:999rpx; padding:5rpx 10rpx; font-size:20rpx; margin-right:8rpx; }
.compact { display:flex; width:100%; min-width:0; }
.compact .cover { width:190rpx; height:190rpx; aspect-ratio:auto; flex:none; }
.compact .body { flex:1; }
.featured { width:560rpx; }
