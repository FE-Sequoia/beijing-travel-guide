.greeting { color:var(--muted); font-size:24rpx; letter-spacing:2rpx; margin-bottom:20rpx; }.hero { background:linear-gradient(135deg,var(--ink-green),#397565); color:#FFF; border-radius:28rpx; padding:38rpx 32rpx 28rpx; }.hero .eyebrow { color:#FFF; opacity:.78; font-size:20rpx; letter-spacing:3rpx; }.hero-title { font-size:46rpx; line-height:1.35; font-weight:700; margin:24rpx 0 34rpx; }.search { display:flex; align-items:center; background:rgba(255,255,255,.9); color:var(--muted); border-radius:14rpx; padding:20rpx 22rpx; font-size:27rpx; }.search-icon { position:relative; width:28rpx; height:28rpx; flex:none; border:4rpx solid var(--ink-green); border-radius:50%; }.search-icon::after { content:''; position:absolute; width:12rpx; height:4rpx; right:-9rpx; bottom:-5rpx; background:var(--ink-green); border-radius:999rpx; transform:rotate(45deg); transform-origin:left center; }.search text { margin-left:20rpx; font-size:24rpx; }.category-grid { display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:16rpx; }.category { display:flex; min-width:0; height:138rpx; flex-direction:column; align-items:center; justify-content:center; border-radius:18rpx; font-size:23rpx; text-align:center; }.emoji { font-size:42rpx; margin-bottom:10rpx; }.featured-grid { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:18rpx; }.section-gap place-card { display:block; width:100%; margin-bottom:18rpx; }.section-gap .featured-grid place-card { margin-bottom:0; }
.itinerary-row { white-space:nowrap; }.itinerary-card { display:inline-block; vertical-align:top; box-sizing:border-box; width:360rpx; min-height:210rpx; padding:24rpx; margin-right:16rpx; border-radius:24rpx; white-space:normal; background:var(--surface); border:1rpx solid rgba(38,50,56,.06); box-shadow:0 10rpx 28rpx rgba(53,72,65,.045); }.itinerary-days { color:var(--vermilion); font-size:24rpx; font-weight:700; }.itinerary-title { margin-top:12rpx; font-size:30rpx; font-weight:700; }.itinerary-summary { margin-top:12rpx; color:var(--muted); font-size:22rpx; line-height:1.6; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
