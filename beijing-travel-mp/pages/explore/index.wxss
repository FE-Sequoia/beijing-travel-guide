.page-heading { font-size:44rpx; font-weight:700; margin:20rpx 0 26rpx; }.page-heading text { display:block; color:var(--muted); font-size:23rpx; font-weight:400; line-height:1.65; margin-top:10rpx; }.search-box { display:flex; align-items:center; min-width:0; height:104rpx; background:rgba(255,252,247,.78); border:1rpx solid rgba(38,50,56,.05); border-radius:16rpx; padding:0 26rpx; color:var(--ink-green); }.search-icon { position:relative; width:32rpx; height:32rpx; flex:none; border:4rpx solid var(--ink-green); border-radius:50%; }.search-icon::after { content:''; position:absolute; width:14rpx; height:4rpx; right:-10rpx; bottom:-5rpx; background:var(--ink-green); border-radius:999rpx; transform:rotate(45deg); transform-origin:left center; }.search-box input { flex:1; min-width:0; height:100%; padding:0 0 0 24rpx; font-size:28rpx; line-height:104rpx; }.filters { width:100%; white-space:nowrap; margin:26rpx 0 18rpx; }.filter { display:inline-block; padding:13rpx 22rpx; background:rgba(228,239,233,.72); color:var(--muted); border-radius:30rpx; margin-right:12rpx; font-size:23rpx; }.filter.selected { color:#FFF; background:var(--ink-green); }.result-bar { display:flex; min-width:0; justify-content:space-between; align-items:center; color:var(--muted); font-size:22rpx; margin-bottom:18rpx; }.sort { color:var(--ink-green); background:rgba(228,239,233,.72); border-radius:20rpx; padding:9rpx 16rpx; }.list place-card { display:block; width:100%; margin-bottom:18rpx; }
