.card { width:100%; min-width:0; overflow:hidden; background:#FFFDF9; border-radius:20rpx; box-shadow:0 8rpx 28rpx rgba(53,72,65,.07); }.cover { width:100%; height:220rpx; background:#E8F2EC; }.fallback { display:flex; align-items:flex-end; padding:20rpx; color:#FFF; font-size:24rpx; font-weight:700; background:linear-gradient(135deg,#2E7D6B,#8BB59D); }.body { min-width:0; padding:20rpx; }.category { color:#2E7D6B; font-size:21rpx; }.name { font-size:31rpx; font-weight:700; margin-top:7rpx; }.summary { color:#718096; font-size:23rpx; line-height:1.6; margin-top:9rpx; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }.tags { margin-top:12rpx; }.tag { color:#718096; background:#F1F4F0; border-radius:8rpx; padding:5rpx 10rpx; font-size:20rpx; margin-right:8rpx; }.compact { display:flex; width:100%; }.compact .cover { width:190rpx; height:190rpx; flex:none; }.compact .body { flex:1; }.featured { width:560rpx; }
