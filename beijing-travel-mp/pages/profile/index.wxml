<scroll-view scroll-y class="page safe-bottom"><view class="profile-head"><view class="avatar">京</view><view><view class="hello">我的北京</view><view class="muted">把喜欢的地方留在这里</view></view></view><view class="section"><view class="section-title">我的收藏</view><place-card wx:for="{{favorites}}" wx:key="id" place="{{item}}" bind:tap="onPlace"></place-card><empty-state wx:if="{{!favorites.length}}" title="还没有收藏" description="在景点详情页点亮收藏，方便下次再看"></empty-state></view><view class="section"><view class="section-title"><text>阅读历史</text><text wx:if="{{history.length}}" class="clear" bindtap="clearHistory">清空</text></view><place-card wx:for="{{history}}" wx:key="id" place="{{item}}" bind:tap="onPlace"></place-card><empty-state wx:if="{{!history.length}}" title="还没有阅读记录" description="探索一些景点，最近看过的内容会出现在这里"></empty-state></view></scroll-view>
