.detail { width:100%; min-height:100vh; }.hero { width:100%; height:430rpx; background:#E8F2EC; }.fallback { display:flex; align-items:flex-end; padding:34rpx; color:#FFF; background:linear-gradient(135deg,#2E7D6B,#8BB59D); font-size:34rpx; font-weight:700; }.body { min-width:0; padding:28rpx 30rpx 60rpx; }.category { color:#2E7D6B; font-size:23rpx; }.title-row { display:flex; min-width:0; align-items:center; justify-content:space-between; margin-top:10rpx; }.title { min-width:0; font-size:48rpx; font-weight:700; }.favorite { width:68rpx; height:68rpx; flex:none; border-radius:50%; background:#F3EFE8; display:flex; align-items:center; justify-content:center; color:#B9513A; font-size:38rpx; }.favorite.active { background:#F9E8E2; }.summary { color:#718096; font-size:27rpx; line-height:1.7; margin-top:16rpx; }.tags { margin-top:18rpx; }.tag { display:inline-block; color:#2E7D6B; background:#E8F2EC; border-radius:8rpx; padding:7rpx 12rpx; font-size:21rpx; margin-right:10rpx; }.info { display:flex; min-width:0; margin-top:28rpx; padding:22rpx; }.info-item { flex:1; min-width:0; color:#263238; font-size:23rpx; }.info-label { color:#718096; font-size:20rpx; margin-bottom:8rpx; }.section { margin-top:36rpx; }.section-title { font-size:32rpx; font-weight:700; margin-bottom:12rpx; }.copy { color:#4A5568; font-size:27rpx; line-height:1.85; }
.related { margin-top:36rpx; padding:24rpx; }.related-item { display:flex; justify-content:space-between; align-items:center; min-width:0; padding:20rpx 0; border-top:1rpx solid #E8ECEA; color:#2E7D6B; font-size:27rpx; }
