.row { display:flex; min-width:0; justify-content:space-between; align-items:flex-end; margin-bottom:20rpx; padding-bottom:16rpx; border-bottom:1rpx solid rgba(38,50,56,.1); }
.row > view { min-width:0; }
.title { font-size:36rpx; font-weight:700; }
.subtitle { color:var(--muted); font-size:23rpx; margin-top:6rpx; }
.action { flex:none; color:var(--ink-green); font-size:22rpx; font-weight:600; letter-spacing:.04em; }
