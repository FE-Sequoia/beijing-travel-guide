<scroll-view wx:if="{{place}}" scroll-y class="detail safe-bottom"><image class="hero" src="{{place.cover}}" mode="aspectFill"></image><view class="body"><view class="category">{{place.categoryId}}</view><view class="title-row"><view class="title">{{place.name}}</view><view class="favorite {{favorite ? 'active' : ''}}" bindtap="toggleFavorite">{{favorite ? '♥' : '♡'}}</view></view><view class="summary">{{place.summary}}</view><view class="tags"><text wx:for="{{place.tags}}" wx:key="*this" class="tag">{{item}}</text></view><view class="info card"><view wx:for="{{place.info}}" wx:key="label" class="info-item"><view class="info-label">{{item.label}}</view><view>{{item.value}}</view></view></view><view wx:for="{{place.sections}}" wx:key="title" class="section"><view class="section-title">{{item.title}}</view><view class="copy">{{item.body}}</view></view></view></scroll-view><empty-state wx:else title="找不到这处风景" description="这条内容可能还没有加入本地攻略" button-text="返回" bind:actiontap="back"></empty-state>
