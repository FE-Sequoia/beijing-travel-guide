.greeting { color:#718096; font-size:24rpx; letter-spacing:2rpx; margin-bottom:20rpx; }.hero { background:linear-gradient(135deg,#2E7D6B,#5E9A83); color:#FFF; border-radius:28rpx; padding:38rpx 32rpx 28rpx; }.eyebrow { opacity:.75; font-size:20rpx; letter-spacing:3rpx; }.hero-title { font-size:46rpx; line-height:1.35; font-weight:700; margin:24rpx 0 34rpx; }.search { background:rgba(255,255,255,.94); color:#718096; border-radius:14rpx; padding:20rpx 22rpx; font-size:27rpx; }.search text { margin-left:12rpx; font-size:24rpx; }.category-grid { display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:16rpx; }.category { display:flex; min-width:0; height:138rpx; flex-direction:column; align-items:center; justify-content:center; border-radius:18rpx; font-size:23rpx; text-align:center; }.emoji { font-size:42rpx; margin-bottom:10rpx; }.places { white-space:nowrap; }.places place-card { display:inline-block; vertical-align:top; margin-right:18rpx; }.section-gap place-card { display:block; width:100%; margin-bottom:18rpx; }
.itinerary-row { white-space:nowrap; }.itinerary-card { display:inline-block; vertical-align:top; box-sizing:border-box; width:360rpx; min-height:210rpx; padding:24rpx; margin-right:16rpx; border-radius:20rpx; white-space:normal; background:#FFFDF9; box-shadow:0 8rpx 28rpx rgba(53,72,65,.07); }.itinerary-days { color:#B9513A; font-size:24rpx; font-weight:700; }.itinerary-title { margin-top:12rpx; font-size:30rpx; font-weight:700; }.itinerary-summary { margin-top:12rpx; color:#718096; font-size:22rpx; line-height:1.6; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
